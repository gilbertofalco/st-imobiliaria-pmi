rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null && request.auth.token.email is string;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function isAuthorized() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/usuarios/$(userEmail()));
    }

    function userData() {
      return firestore.get(/databases/(default)/documents/usuarios/$(userEmail())).data;
    }

    function isAdmin() {
      return isAuthorized() && userData().nivel in ['admin', 'master'];
    }

    function hasSafeImageExtension(fileName) {
      return fileName.matches('.*[.](jpg|jpeg|png|webp|JPG|JPEG|PNG|WEBP)$');
    }

    function isSafeImage(fileName) {
      return request.resource != null
        && request.resource.size <= 20 * 1024 * 1024
        && (
          hasSafeImageExtension(fileName)
          || (
            request.resource.contentType is string
            && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)')
          )
        );
    }

    function isAnaliseFolder(folder) {
      return folder.matches('fotos_(alvo|comp_[0-9]+)');
    }

    match /corretores/{fileName} {
      allow read: if isAuthorized();
      allow create, update: if isAdmin() && isSafeImage(fileName);
      allow delete: if isAdmin();
    }

    match /{folder}/{fileName} {
      allow read: if signedIn() && isAnaliseFolder(folder);
      allow create, update: if signedIn() && isAnaliseFolder(folder) && isSafeImage(fileName);
      allow delete: if signedIn() && isAnaliseFolder(folder);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
